---
// InstagramFeed.astro — Simple CTA to connect on Instagram
---

<section class="section instagram-cta">
  <div class="container">
    <div class="text-center fade-in">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="instagram-cta__icon">
        <rect x="2" y="2" width="20" height="20" rx="5" />
        <circle cx="12" cy="12" r="5" />
        <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
      </svg>
      <h2>See More on Instagram</h2>
      <p class="instagram-cta__text">Follow along for behind-the-scenes peeks, finished pieces, and upcoming workshop announcements.</p>
      <a href="https://instagram.com/piecexpiece26" target="_blank" rel="noopener" class="btn btn--primary">
        Follow @piecexpiece26
      </a>
    </div>
  </div>
</section>
