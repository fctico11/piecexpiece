---
// Footer.astro
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <!-- Brand Column -->
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <img src="/images/logo.png" alt="Piece x Piece Mosaics">
        </a>
        <p class="footer__tagline">Pop-up mosaic workshops designed for all skill levels. Create something beautiful, piece by piece.</p>
      </div>

      <!-- Quick Links -->
      <div class="footer__col">
        <h4 class="footer__heading">Explore</h4>
        <nav class="footer__nav">
          <a href="/">Home</a>
          <a href="/classes">Classes</a>
          <a href="/about">About</a>
          <a href="/gallery">Gallery</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>

      <!-- Connect -->
      <div class="footer__col">
        <h4 class="footer__heading">Connect</h4>
        <div class="footer__contact-list">
          <a href="mailto:piecexpiecemosaics@gmail.com" class="footer__contact-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            piecexpiecemosaics@gmail.com
          </a>
          <a href="https://instagram.com/piecexpiece26" target="_blank" rel="noopener" class="footer__contact-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
            @piecexpiece26
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="footer__divider">
      <span></span><span></span><span></span>
    </div>

    <!-- Bottom Bar -->
    <div class="footer__bottom">
      <p class="footer__copy">&copy; 2025 Piece x Piece Mosaics. All rights reserved.</p>
      <div class="footer__social">
        <a href="https://instagram.com/piecexpiece26" target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <circle cx="12" cy="12" r="5" />
            <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none" />
          </svg>
        </a>
        <a href="mailto:piecexpiecemosaics@gmail.com" aria-label="Email">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
