---
import Base from '../layouts/Base.astro';
import CTABanner from '../components/CTABanner.astro';

const title = "About — Piece x Piece Mosaics";
const description = "Learn about Piece x Piece Mosaics — pop-up workshops blending artistic expression with the calming benefits of art therapy.";
---

<Base title={title} description={description}>
  <!-- About Hero -->
  <section class="about-hero section">
    <div class="container">
      <div class="fade-in">
        <span class="section__label">Our Story</span>
        <h1>About Piece x Piece</h1>
      </div>
      <div class="about-hero__img fade-in fade-in-delay-1">
        <img src="/images/about-lifestyle.png" alt="Hands placing mosaic tiles in a workshop setting" />
      </div>
    </div>
  </section>

  <!-- About Text -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <div class="about-text fade-in">
        <p>Piece x Piece is a pop-up mosaic workshop designed for all skill levels. We offer an accessible, hands-on creative experience where everyone is welcome — no artistic background required.</p>
        <p>Our workshops are thoughtfully designed to foster relaxation, creativity, and a sense of accomplishment, blending artistic expression with the calming benefits of art therapy.</p>
        <p>Each session includes all the materials you need to create your own mosaic piece. Just bring yourself and enjoy the process of this ancient art form.</p>
        <p>We look forward to creating with you.</p>
      </div>
    </div>
  </section>

  <!-- What to Expect -->
  <section class="section section--beige">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section__label">The Workshop Experience</span>
        <h2>What to Expect</h2>
      </div>
      <div class="expect-grid">
        <div class="expect-card fade-in fade-in-delay-1">
          <div class="expect-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3>Relaxing Atmosphere</h3>
          <p>A calm, welcoming space designed to help you unwind and focus on creating.</p>
        </div>
        <div class="expect-card fade-in fade-in-delay-2">
          <div class="expect-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Small Group Setting</h3>
          <p>Intimate classes with personalized guidance so everyone gets hands-on attention.</p>
        </div>
        <div class="expect-card fade-in fade-in-delay-3">
          <div class="expect-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3>Beginner-Friendly</h3>
          <p>No experience needed — step-by-step instruction makes it easy for everyone.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section__label">Everything You Need</span>
        <h2>What's Included</h2>
      </div>
      <div class="included-grid">
        <div class="included-card fade-in fade-in-delay-1">
          <div class="included-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <h3>All Materials</h3>
          <p>Glass tiles, bases, adhesive, grout — everything provided.</p>
        </div>
        <div class="included-card fade-in fade-in-delay-2">
          <div class="included-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </div>
          <h3>Step-by-Step Guidance</h3>
          <p>Clear instruction from start to finish.</p>
        </div>
        <div class="included-card fade-in fade-in-delay-3">
          <div class="included-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
          </div>
          <h3>Your Finished Piece</h3>
          <p>Take home a mosaic you made with your own hands.</p>
        </div>
        <div class="included-card fade-in">
          <div class="included-card__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
          </div>
          <h3>Good Vibes</h3>
          <p>Light refreshments and great company included.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section" style="padding-top: 0;">
    <div class="container">
      <CTABanner 
        title="Ready to create?"
        description="Browse our upcoming workshops and reserve your spot."
        buttonText="View Classes"
        buttonLink="/classes"
      />
    </div>
  </section>
</Base>
