---
import Base from '../layouts/Base.astro';

const title = "Contact — Piece x Piece Mosaics";
const description = "Get in touch with Piece x Piece Mosaics. Book a private workshop, ask a question, or say hello.";
---

<Base title={title} description={description}>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container fade-in">
      <span class="section__label">Say Hello</span>
      <h1>Contact Us</h1>
      <p>Have a question or want to book a private workshop? We'd love to hear from you.</p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section" style="padding-top: 40px;">
    <div class="container">
      <form class="contact-form fade-in" id="contact-form">
        <div class="form-group">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" placeholder="Your name" required>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="your@email.com" required>
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" placeholder="Tell us what you're interested in — private events, group bookings, questions about classes…" required></textarea>
        </div>
        <button type="submit" class="btn btn--primary btn--full">Send Message</button>
      </form>

      <div class="contact-info fade-in">
        <p style="margin: 0 auto 12px; font-size: 0.95rem; color: var(--color-text-light);">You can also find us on Instagram or send a DM.</p>
        <a href="https://instagram.com" target="_blank" rel="noopener" style="display: inline-flex; align-items: center; gap: 8px;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
          @piecexpiece.mosaics
        </a>
        <p style="margin: 16px auto 0; font-size: 0.82rem; color: var(--color-text-light);">We also accept Venmo as an alternative payment method for workshops. Just reach out for details.</p>
      </div>
    </div>
  </section>

  <script>
    const contactForm = document.getElementById('contact-form');
    if (contactForm) {
      contactForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const btn = contactForm.querySelector('button[type="submit"]') as HTMLButtonElement;
        if (!btn) return;
        const originalText = btn.textContent;
        btn.textContent = 'Sending…';
        btn.disabled = true;
        setTimeout(() => {
          btn.textContent = 'Message Sent ✓';
          btn.style.background = 'var(--color-turquoise-vibrant)';
          setTimeout(() => {
            (contactForm as HTMLFormElement).reset();
            btn.textContent = originalText;
            btn.disabled = false;
            btn.style.background = '';
          }, 2500);
        }, 1200);
      });
    }
  </script>
</Base>
