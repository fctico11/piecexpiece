---
import Base from '../layouts/Base.astro';
import ClassCard from '../components/ClassCard.astro';
import CTABanner from '../components/CTABanner.astro';
import CheckoutModal from '../components/CheckoutModal.astro';
import ClassDetailModal from '../components/ClassDetailModal.astro';
import classData from '../data/classes.json';

const title = "Classes & Private Workshops — Piece x Piece Mosaics";
const description = "Browse upcoming mosaic classes, book private lessons, or plan a private mosaic workshop for birthdays, events, and small groups.";

// Read from classes.json — published at deploy time when client adds/edits a class
const allClasses = (classData.classes as any[]).sort(
  (a, b) => new Date(a.date).getTime() - new Date(b.date).getTime()
);

function fmtClassDate(cls: any) {
  const d = new Date(cls.date + 'T00:00:00');
  const day = d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
  return `${day} · ${cls.time}`;
}
---

<Base title={title} description={description}>
  <!-- Page Header -->
  <section class="page-header mosaic-section mosaic-section--light mosaic-clip-1">
    <div class="container fade-in">
      <span class="section__label" style="color: var(--color-primary-dark);">Book a Mosaic Experience</span>
      <h1>Mosaic Classes & Private Workshops</h1>
      <p style="color: var(--color-primary-dark);">Join an upcoming public class, schedule a private lesson, or plan a hands-on mosaic workshop for your group.</p>
      <div class="classes-jump-links" aria-label="Class page sections">
        <a href="#upcoming-classes">Upcoming Classes</a>
        <a href="#private-lessons">Private Lessons</a>
        <a href="#private-events">Private Events</a>
      </div>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- Classes Grid -->
  <section id="upcoming-classes" class="section mosaic-section mosaic-section--amber mosaic-clip-1" style="padding-top: 40px;">
    <div class="container">
      <div class="section-heading fade-in">
        <span class="section__label">Public Schedule</span>
        <h2>Upcoming Classes</h2>
        <p>Reserve a seat in one of our scheduled workshops. Materials are provided, beginners are welcome, and every class ends with a finished piece to take home.</p>
      </div>

      <div class="classes-grid">
        {allClasses.length > 0 ? (
          allClasses.map((cls: any, index: number) => (
            <ClassCard
              id={cls.id}
              title={cls.title}
              description={cls.description}
              dateStr={fmtClassDate(cls)}
              duration={cls.duration}
              location={cls.location}
              price={`$${cls.price}`}
              imageSrc={cls.image || '/images/gallery-2.jpg'}
              badge={cls.badge}
              totalTickets={cls.totalTickets}
              ticketsSold={cls.ticketsSold || 0}
              delay={`fade-in-delay-${(index % 3) + 1}`}
            />
          ))
        ) : (
          <p style="color:var(--color-text-light);grid-column:1/-1;padding:40px 0;">No upcoming classes at the moment — check back soon!</p>
        )}
      </div>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- Private Offerings -->
  <section class="section mosaic-section mosaic-section--sapphire mosaic-clip-2">
    <div class="container">
      <div class="section-heading fade-in">
        <span class="section__label">Private Booking</span>
        <h2>Make It More Personal</h2>
        <p>Private sessions are designed around your pace, your people, and the kind of mosaic experience you want to create.</p>
      </div>

      <div class="private-options">
        <article id="private-lessons" class="private-option fade-in fade-in-delay-1">
          <div class="private-option__icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
          </div>
          <div class="private-option__body">
            <span class="private-option__eyebrow">One-on-one or small private sessions</span>
            <h3>Private Lessons</h3>
            <p>Personal instruction tailored to your creative goals. Great for beginners, gifts, special occasions, or anyone who wants a slower, focused mosaic experience.</p>
            <ul class="private-option__list">
              <li>Flexible scheduling</li>
              <li>Project guidance and materials included</li>
              <li>Ideal for individuals, pairs, or very small groups</li>
            </ul>
          </div>
          <a href="/contact?type=private-lesson" class="btn btn--turquoise">Book a Private Lesson</a>
        </article>

        <article id="private-events" class="private-option fade-in fade-in-delay-2">
          <div class="private-option__icon private-option__icon--coral">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h18"/><path d="M3 8a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v11H3Z"/><path d="M7 6V4"/><path d="M17 6V4"/><path d="M8 13h.01"/><path d="M12 13h.01"/><path d="M16 13h.01"/></svg>
          </div>
          <div class="private-option__body">
            <span class="private-option__eyebrow">Birthdays, team outings, parties, and pop-ups</span>
            <h3>Private Workshops & Events</h3>
            <p>Bring a mosaic workshop to your celebration, gathering, or organization. We can shape the project, timing, and setup around your group.</p>
            <ul class="private-option__list">
              <li>Birthday parties, bachelorettes, team events, and family gatherings</li>
              <li>Group-friendly project options</li>
              <li>Available for hosted or pop-up workshop formats</li>
            </ul>
          </div>
          <a href="/contact?type=private-event" class="btn btn--primary">Inquire About Events</a>
        </article>
      </div>

      <CTABanner 
        title="Not Sure What Fits?"
        description="Tell us your date, group size, and the kind of experience you have in mind. We'll help you choose the right format."
        buttonText="Start an Inquiry"
        buttonLink="/contact"
      />
    </div>
  </section>
  <CheckoutModal />
  <ClassDetailModal />
</Base>
