---
export const prerender = false;
import Base from '../../layouts/Base.astro';
const className = Astro.url.searchParams.get('class') ?? 'your class';
const location  = Astro.url.searchParams.get('location') ?? '';
const mapsUrl   = location ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(location)}` : '';
---
<Base title="You're Registered! — Piece x Piece" description="Your spot is confirmed.">
  <style>
    .success-wrap {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 100px 24px 60px;
      position: relative;
      overflow: hidden;
      background: linear-gradient(160deg, #f5f0ea 0%, #e8f4f3 60%, #d6eeec 100%);
    }

    /* Decorative mosaic tiles floating in background */
    .tile {
      position: absolute;
      border-radius: 4px;
      opacity: 0.18;
      animation: float linear infinite;
    }
    .tile:nth-child(1)  { width:52px;height:52px;background:var(--color-turquoise);top:8%;left:6%;animation-duration:14s;animation-delay:0s;transform:rotate(15deg); }
    .tile:nth-child(2)  { width:32px;height:32px;background:var(--color-amber);top:18%;left:18%;animation-duration:18s;animation-delay:-4s;transform:rotate(-10deg); }
    .tile:nth-child(3)  { width:68px;height:68px;background:var(--color-coral);top:5%;right:10%;animation-duration:20s;animation-delay:-2s;transform:rotate(30deg); }
    .tile:nth-child(4)  { width:40px;height:40px;background:var(--color-emerald);top:30%;right:5%;animation-duration:16s;animation-delay:-8s;transform:rotate(-20deg); }
    .tile:nth-child(5)  { width:24px;height:24px;background:var(--color-sapphire);bottom:25%;left:8%;animation-duration:22s;animation-delay:-3s;transform:rotate(45deg); }
    .tile:nth-child(6)  { width:56px;height:56px;background:var(--color-amber);bottom:15%;right:12%;animation-duration:17s;animation-delay:-6s;transform:rotate(-35deg); }
    .tile:nth-child(7)  { width:36px;height:36px;background:var(--color-turquoise);bottom:35%;left:20%;animation-duration:19s;animation-delay:-10s;transform:rotate(20deg); }
    .tile:nth-child(8)  { width:28px;height:28px;background:var(--color-coral);top:50%;right:20%;animation-duration:15s;animation-delay:-1s;transform:rotate(-15deg); }

    @keyframes float {
      0%   { transform: translateY(0px) rotate(var(--r, 15deg)); }
      50%  { transform: translateY(-18px) rotate(calc(var(--r, 15deg) + 8deg)); }
      100% { transform: translateY(0px) rotate(var(--r, 15deg)); }
    }

    .success-card {
      position: relative;
      background: white;
      border-radius: 24px;
      padding: 56px 48px 48px;
      max-width: 520px;
      width: 100%;
      text-align: center;
      box-shadow: 0 8px 40px rgba(26,58,92,0.10), 0 2px 8px rgba(26,58,92,0.06);
      animation: cardIn 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    }

    @keyframes cardIn {
      from { opacity: 0; transform: scale(0.88) translateY(24px); }
      to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    .check-ring {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--color-turquoise) 0%, var(--color-emerald) 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 28px;
      box-shadow: 0 0 0 12px rgba(95,184,176,0.15), 0 0 0 24px rgba(95,184,176,0.06);
      animation: ringPop 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) 0.2s both;
    }

    @keyframes ringPop {
      from { opacity: 0; transform: scale(0.5); }
      to   { opacity: 1; transform: scale(1); }
    }

    .success-card h1 {
      font-size: 2.4rem;
      color: var(--color-primary);
      margin: 0 0 12px;
      line-height: 1.1;
    }

    .class-name-badge {
      display: inline-block;
      background: linear-gradient(135deg, rgba(95,184,176,0.15), rgba(95,184,176,0.08));
      border: 1.5px solid rgba(95,184,176,0.4);
      color: var(--color-primary);
      font-weight: 700;
      font-size: 1.05rem;
      padding: 6px 18px;
      border-radius: 100px;
      margin-bottom: 20px;
    }

    .success-card p {
      color: var(--color-text-light);
      font-size: 1.05rem;
      line-height: 1.6;
      margin: 0 0 32px;
    }

    .details-row {
      display: flex;
      gap: 12px;
      justify-content: center;
      margin-bottom: 36px;
    }

    .detail-chip {
      display: flex;
      align-items: center;
      gap: 6px;
      background: #f5f0ea;
      border-radius: 100px;
      padding: 7px 14px;
      font-size: 0.82rem;
      color: var(--color-primary);
      font-weight: 500;
    }

    .detail-chip svg { flex-shrink: 0; }

    .btn-row {
      display: flex;
      gap: 12px;
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-success-primary {
      background: var(--color-primary);
      color: white;
      padding: 14px 28px;
      border-radius: 100px;
      font-weight: 600;
      font-size: 0.9rem;
      letter-spacing: 0.06em;
      text-decoration: none;
      text-transform: uppercase;
      transition: background 0.2s, transform 0.15s;
      display: inline-block;
    }
    .btn-success-primary:hover { background: #122a45; transform: translateY(-1px); }

    .btn-success-ghost {
      background: transparent;
      color: var(--color-primary);
      padding: 14px 28px;
      border-radius: 100px;
      font-weight: 600;
      font-size: 0.9rem;
      letter-spacing: 0.06em;
      text-decoration: none;
      text-transform: uppercase;
      border: 2px solid rgba(26,58,92,0.2);
      transition: border-color 0.2s, transform 0.15s;
      display: inline-block;
    }
    .btn-success-ghost:hover { border-color: var(--color-primary); transform: translateY(-1px); }

    .confetti-line {
      font-size: 1.6rem;
      margin-bottom: 8px;
      animation: wiggle 1s ease 0.8s both;
    }

    @keyframes wiggle {
      0%,100% { transform: rotate(0deg); }
      25% { transform: rotate(-10deg); }
      75% { transform: rotate(10deg); }
    }

    .directions-block {
      display: flex;
      align-items: center;
      gap: 14px;
      background: linear-gradient(135deg, #f0faf9, #e8f4f3);
      border: 1.5px solid rgba(95,184,176,0.35);
      border-radius: 14px;
      padding: 14px 16px;
      margin-bottom: 28px;
      text-decoration: none;
      transition: border-color 0.2s, box-shadow 0.2s, transform 0.15s;
      text-align: left;
    }
    .directions-block:hover {
      border-color: var(--color-turquoise);
      box-shadow: 0 4px 16px rgba(95,184,176,0.2);
      transform: translateY(-1px);
    }
    .directions-pin {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--color-turquoise), var(--color-emerald));
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .directions-text {
      flex: 1;
      min-width: 0;
    }
    .directions-label {
      display: block;
      font-size: 0.72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--color-turquoise);
      margin-bottom: 2px;
    }
    .directions-address {
      display: block;
      font-size: 0.88rem;
      color: var(--color-primary);
      font-weight: 500;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .directions-cta {
      display: flex;
      align-items: center;
      gap: 4px;
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--color-turquoise);
      white-space: nowrap;
      flex-shrink: 0;
    }

    @media (max-width: 560px) {
      .success-wrap { padding: 80px 16px 24px; align-items: flex-start; }
      .success-card { padding: 28px 20px 24px; border-radius: 18px; }
      .check-ring { width: 64px; height: 64px; margin-bottom: 16px; box-shadow: 0 0 0 8px rgba(95,184,176,0.15), 0 0 0 16px rgba(95,184,176,0.06); }
      .check-ring svg { width: 28px; height: 28px; }
      .confetti-line { font-size: 1.3rem; margin-bottom: 6px; }
      .success-card h1 { font-size: 1.7rem; margin-bottom: 8px; }
      .class-name-badge { font-size: 0.9rem; padding: 5px 14px; margin-bottom: 12px; }
      .success-card p { font-size: 0.88rem; margin-bottom: 16px; }
      .details-row { flex-direction: row; flex-wrap: wrap; justify-content: center; gap: 8px; margin-bottom: 14px; }
      .detail-chip { font-size: 0.75rem; padding: 5px 10px; }
      .directions-block { padding: 10px 12px; margin-bottom: 18px; gap: 10px; }
      .directions-pin { width: 32px; height: 32px; }
      .directions-pin svg { width: 15px; height: 15px; }
      .directions-label { font-size: 0.65rem; }
      .directions-address { font-size: 0.8rem; }
      .directions-cta { font-size: 0.72rem; }
      .btn-row { gap: 8px; }
      .btn-success-primary, .btn-success-ghost { padding: 12px 20px; font-size: 0.8rem; }
    }
  </style>

  <div class="success-wrap">
    <!-- Floating mosaic tiles -->
    <div class="tile"></div>
    <div class="tile"></div>
    <div class="tile"></div>
    <div class="tile"></div>
    <div class="tile"></div>
    <div class="tile"></div>
    <div class="tile"></div>
    <div class="tile"></div>

    <div class="success-card">
      <div class="confetti-line">🎉</div>
      <div class="check-ring">
        <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.8" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>

      <h1>You're in!</h1>
      <div class="class-name-badge">{className}</div>

      <p>
        Your spot is confirmed — we can't wait to create with you.<br>
        Check your email for your receipt and class details.
      </p>

      <div class="details-row">
        <div class="detail-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="M16 2v4M8 2v4M4 10h16"/></svg>
          Receipt sent to your email
        </div>
        <div class="detail-chip">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Secure payment
        </div>
      </div>

      {mapsUrl && (
        <a href={mapsUrl} target="_blank" rel="noopener noreferrer" class="directions-block">
          <div class="directions-pin">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="directions-text">
            <span class="directions-label">Venue</span>
            <span class="directions-address">{location}</span>
          </div>
          <div class="directions-cta">
            Get Directions
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </div>
        </a>
      )}

      <div class="btn-row">
        <a href="/classes" class="btn-success-primary">Browse More Classes</a>
        <a href="/" class="btn-success-ghost">Back to Home</a>
      </div>
    </div>
  </div>
</Base>
