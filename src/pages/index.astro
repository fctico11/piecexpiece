---
import Base from '../layouts/Base.astro';
import ClassCard from '../components/ClassCard.astro';
import CTABanner from '../components/CTABanner.astro';
import Lightbox from '../components/Lightbox.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import { getActiveClasses } from '../lib/stripe';

const title = "Piece x Piece Mosaics — Pop-Up Mosaic Workshops";
const description = "Pop-up mosaic workshops designed for all skill levels. Create beautiful mosaic art in a relaxing, hands-on experience. No experience needed.";

// Fetch dynamic classes from Stripe and limit to top 3 for the homepage
const stripeClasses = await getActiveClasses();
const featuredClasses = stripeClasses.slice(0, 3);
---

<Base title={title} description={description}>
  <!-- Hero -->
  <section class="hero mosaic-section mosaic-section--light">
    <div class="container">
      <div class="hero__layout">
        <div class="hero__content fade-in">
          <h1>Pop-up mosaic workshops, <em>piece by piece.</em></h1>
          <p class="hero__sub">Pop-up mosaic workshops designed for all skill levels. No experience needed.</p>
          <div class="hero__buttons">
            <a href="/classes" class="btn btn--primary">View Classes</a>
            <a href="/contact" class="btn btn--outline">Book a Workshop</a>
          </div>
        </div>
        <div class="hero__image fade-in fade-in-delay-2">
          <img src="/images/gallery-7.jpg" alt="Beautiful mosaic art created at a Piece x Piece workshop" />
        </div>
      </div>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- Intro -->
  <section class="section intro mosaic-section mosaic-section--coral mosaic-clip-1">
    <div class="container">
      <div class="fade-in">
        <span class="section__label" style="color: var(--color-primary-dark);">The Experience</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="intro-icon">
          <circle cx="12" cy="7" r="3"/><path d="M5.5 21v-2a4.5 4.5 0 0 1 4.5-4.5h4a4.5 4.5 0 0 1 4.5 4.5v2"/><circle cx="4" cy="9" r="2"/><path d="M2 21v-1.5A3.5 3.5 0 0 1 4.5 16"/><circle cx="20" cy="9" r="2"/><path d="M22 21v-1.5A3.5 3.5 0 0 0 19.5 16"/>
        </svg>
        <h2>Art-making for everyone</h2>
        <p class="intro__text" style="color: var(--color-primary-dark); font-weight: 400;">Step away from the everyday and into a calming creative space. Our mosaic workshops blend artistic expression with the soothing benefits of art therapy — perfect for date nights, girls' nights, team-building, or simply treating yourself to something beautiful.</p>
      </div>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- Featured Classes -->
  <section class="section mosaic-section mosaic-section--emerald mosaic-clip-2">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section__label" style="color: var(--color-primary-dark);">Upcoming Workshops</span>
        <h2>Featured Classes</h2>
      </div>
      <div class="classes-grid">
        {featuredClasses.length > 0 ? (
          featuredClasses.map((cls, index) => (
            <ClassCard 
              title={cls.title}
              description={cls.description}
              dateStr={cls.dateStr}
              duration={cls.duration}
              location={cls.location}
              price={cls.price}
              imageSrc={cls.imageSrc}
              badge={cls.badge}
              paymentLink={cls.paymentLink}
              delay={`fade-in-delay-${(index % 3) + 1}`}
            />
          ))
        ) : (
          <>
            <ClassCard 
              title="Suncatcher Mosaic Workshop"
              description="Create a stunning glass mosaic suncatcher to hang in your window."
              dateStr="Sat, May 17 · 2:00 PM"
              location="Studio 42, Brooklyn NY"
              price="$65"
              imageSrc="/images/gallery-2.jpg"
              badge="Limited Spots"
              delay="fade-in-delay-1"
            />
            <ClassCard 
              title="Mosaic Coaster Set"
              description="Design and grout a set of four beautiful mosaic coasters to take home."
              dateStr="Sun, May 25 · 11:00 AM"
              location="The Maker Space, Williamsburg"
              price="$55"
              imageSrc="/images/gallery-3.jpg"
              delay="fade-in-delay-2"
            />
            <ClassCard 
              title="Mosaic Picture Frame"
              description="Craft a one-of-a-kind mosaic frame — perfect as a gift or keepsake."
              dateStr="Sat, Jun 7 · 3:00 PM"
              location="Studio 42, Brooklyn NY"
              price="$60"
              imageSrc="/images/gallery-4.jpg"
              delay="fade-in-delay-3"
            />
          </>
        )}
      </div>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- Gallery Preview -->
  <section class="section mosaic-section mosaic-section--amber mosaic-clip-3">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section__label" style="color: var(--color-primary-dark);">Our Work</span>
        <h2>From Our Workshops</h2>
      </div>
      <div class="gallery-strip fade-in">
        <div class="gallery-strip__item"><img src="/images/gallery-1.jpg" alt="Mosaic artwork" loading="lazy"></div>
        <div class="gallery-strip__item"><img src="/images/gallery-5.jpg" alt="Workshop in progress" loading="lazy"></div>
        <div class="gallery-strip__item"><img src="/images/gallery-6.jpg" alt="Finished mosaic" loading="lazy"></div>
        <div class="gallery-strip__item"><img src="/images/gallery-8.jpg" alt="Mosaic materials" loading="lazy"></div>
      </div>
      <div class="text-center fade-in" style="margin-top: 48px;">
        <a href="/gallery" class="btn btn--primary">View Full Gallery</a>
      </div>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <InstagramFeed />

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- CTA Banner -->
  <section class="section mosaic-section mosaic-section--sapphire mosaic-clip-2" style="padding-bottom: 120px;">
    <div class="container">
      <CTABanner 
        title="Join our next workshop"
        description="Browse upcoming classes and reserve your spot today."
        buttonText="View Upcoming Classes"
        buttonLink="/classes"
      />
    </div>
  </section>

  <Lightbox />
</Base>
