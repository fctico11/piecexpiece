---
import Base from '../layouts/Base.astro';
import ClassCard from '../components/ClassCard.astro';
import CTABanner from '../components/CTABanner.astro';
import Lightbox from '../components/Lightbox.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import CheckoutModal from '../components/CheckoutModal.astro';
import classData from '../data/classes.json';

const title = "Piece x Piece Mosaics — Pop-Up Mosaic Workshops";
const description = "Pop-up mosaic workshops designed for all skill levels. Create beautiful mosaic art in a relaxing, hands-on experience. No experience needed.";

// Show up to 4 featured classes from classes.json
const allClasses = classData.classes as any[];
const featuredClasses = allClasses
  .filter(c => c.featured)
  .sort((a, b) => new Date(a.date).getTime() - new Date(b.date).getTime())
  .slice(0, 4);

function fmtClassDate(cls: any) {
  const d = new Date(cls.date + 'T00:00:00');
  const day = d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
  return `${day} · ${cls.time}`;
}
---

<Base title={title} description={description}>
  <!-- Hero -->
  <section class="hero mosaic-section mosaic-section--light">
    <div class="container">
      <div class="hero__layout">
        <div class="hero__content fade-in">
          <h1>Pop-up mosaic workshops, <em>piece by piece.</em></h1>
          <p class="hero__sub">Pop-up mosaic workshops designed for all skill levels. No experience needed.</p>
          <div class="hero__buttons">
            <a href="/classes" class="btn btn--primary">View Classes</a>
            <a href="/contact" class="btn btn--outline">Book a Workshop</a>
          </div>
        </div>
        <div class="hero__image fade-in fade-in-delay-2">
          <img src="/images/gallery-7.jpg" alt="Beautiful mosaic art created at a Piece x Piece workshop" />
        </div>
      </div>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- Intro -->
  <section class="section intro mosaic-section mosaic-section--coral mosaic-clip-1">
    <div class="container">
      <div class="intro__layout">
        <div class="intro__content fade-in">
          <div class="intro-mosaic-sparkle" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span>
          </div>
          <span class="section__label" style="color: var(--color-primary-dark);">The Experience</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="intro-icon">
            <circle cx="12" cy="7" r="3"/><path d="M5.5 21v-2a4.5 4.5 0 0 1 4.5-4.5h4a4.5 4.5 0 0 1 4.5 4.5v2"/><circle cx="4" cy="9" r="2"/><path d="M2 21v-1.5A3.5 3.5 0 0 1 4.5 16"/><circle cx="20" cy="9" r="2"/><path d="M22 21v-1.5A3.5 3.5 0 0 0 19.5 16"/>
          </svg>
          <h2>Art-making for everyone</h2>
          <p class="intro__text">Show up as you are. We'll have the glass, tools, grout, guidance, and a relaxed creative setup waiting for you. You bring yourself, settle in, and leave with your own mosaic work of art.</p>
        </div>

        <div class="intro__included fade-in fade-in-delay-2" aria-label="What's included">
          <div class="intro-feature">
            <div class="intro-feature__icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m14.7 6.3 3 3"/><path d="M9 12 3 18v3h3l6-6"/><path d="m6 15 3 3"/><path d="M15 4 6 13"/><path d="m18 7-9 9"/></svg>
            </div>
            <h3>All materials included</h3>
            <p>Colorful glass, tools, adhesive, grout, and finishing supplies are ready when you arrive.</p>
          </div>
          <div class="intro-feature">
            <div class="intro-feature__icon intro-feature__icon--amber">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><path d="m9 9 2 2 4-4"/></svg>
            </div>
            <h3>Guided step by step</h3>
            <p>No mosaic experience needed. We'll help with design, layout, technique, and finishing.</p>
          </div>
          <div class="intro-feature">
            <div class="intro-feature__icon intro-feature__icon--coral">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="13.5" cy="6.5" r=".5" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".5" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".5" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".5" fill="currentColor"/><path d="M12 22a10 10 0 1 1 10-10 4 4 0 0 1-4 4h-1.5a2 2 0 0 0-1.8 2.9l.3.6A1.7 1.7 0 0 1 13.5 22Z"/></svg>
            </div>
            <h3>Leave with finished art</h3>
            <p>Take home a handmade mosaic piece that feels personal, polished, and entirely yours.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- Featured Classes -->
  <section class="section mosaic-section mosaic-section--emerald mosaic-clip-2">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section__label" style="color: var(--color-primary-dark);">Upcoming Workshops</span>
        <h2>Featured Classes</h2>
      </div>
      <div class="classes-grid">
        {featuredClasses.length > 0 ? (
          featuredClasses.map((cls: any, index: number) => (
            <ClassCard
              id={cls.id}
              title={cls.title}
              description={cls.description}
              dateStr={fmtClassDate(cls)}
              duration={cls.duration}
              location={cls.location}
              price={`$${cls.price}`}
              imageSrc={cls.image || '/images/gallery-2.jpg'}
              badge={cls.badge}
              totalTickets={cls.totalTickets}
              ticketsSold={cls.ticketsSold || 0}
              delay={`fade-in-delay-${(index % 4) + 1}`}
            />
          ))
        ) : (
          <p style="color:var(--color-text-light);grid-column:1/-1;text-align:center;padding:40px 0;">
            Classes coming soon — check back shortly!
          </p>
        )}
      </div>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- Gallery Preview -->
  <section class="section mosaic-section mosaic-section--amber mosaic-clip-3">
    <div class="container">
      <div class="text-center fade-in">
        <span class="section__label" style="color: var(--color-primary-dark);">Our Work</span>
        <h2>From Our Workshops</h2>
      </div>
      <div class="gallery-strip fade-in">
        <div class="gallery-strip__item"><img src="/images/gallery-1.jpg" alt="Mosaic artwork" loading="lazy"></div>
        <div class="gallery-strip__item"><img src="/images/gallery-5.jpg" alt="Workshop in progress" loading="lazy"></div>
        <div class="gallery-strip__item"><img src="/images/gallery-6.jpg" alt="Finished mosaic" loading="lazy"></div>
        <div class="gallery-strip__item"><img src="/images/gallery-8.jpg" alt="Mosaic materials" loading="lazy"></div>
      </div>
      <div class="text-center fade-in" style="margin-top: 48px;">
        <a href="/gallery" class="btn btn--primary">View Full Gallery</a>
      </div>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <InstagramFeed />

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- CTA Banner -->
  <section class="section mosaic-section mosaic-section--sapphire mosaic-clip-2" style="padding-bottom: 120px;">
    <div class="container">
      <CTABanner 
        title="Join our next workshop"
        description="Browse upcoming classes and reserve your spot today."
        buttonText="View Upcoming Classes"
        buttonLink="/classes"
      />
    </div>
  </section>

  <Lightbox />
  <CheckoutModal />
</Base>
