---
import Base from '../layouts/Base.astro';
import CTABanner from '../components/CTABanner.astro';
import Lightbox from '../components/Lightbox.astro';

const title = "Gallery — Piece x Piece Mosaics";
const description = "Browse photos of finished mosaic pieces and workshops. Suncatchers, coasters, frames, and more from Piece x Piece workshops.";
---

<Base title={title} description={description}>
  <!-- Page Header -->
  <section class="page-header mosaic-section mosaic-section--light mosaic-clip-1">
    <div class="container fade-in">
      <span class="section__label" style="color: var(--color-primary-dark);">Our Work</span>
      <h1>Gallery</h1>
      <p style="color: var(--color-primary-dark);">A collection of finished pieces and workshop moments.</p>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- Gallery Grid -->
  <section class="section mosaic-section mosaic-section--emerald mosaic-clip-2" style="padding-top: 40px; padding-bottom: 80px;">
    <div class="container">
      <div class="gallery-grid">
        <div class="gallery-item fade-in"><img src="/images/gallery-7.jpg" alt="Large colorful mosaic art" loading="lazy"></div>
        <div class="gallery-item fade-in fade-in-delay-1"><img src="/images/gallery-2.jpg" alt="Finished mosaic piece" loading="lazy"></div>
        <div class="gallery-item fade-in fade-in-delay-2"><img src="/images/gallery-3.jpg" alt="Finished mosaic star" loading="lazy"></div>
        <div class="gallery-item fade-in"><img src="/images/gallery-4.jpg" alt="Spiral mosaic art" loading="lazy"></div>
        <div class="gallery-item fade-in fade-in-delay-1"><img src="/images/gallery-5.jpg" alt="Workshop in progress" loading="lazy"></div>
        <div class="gallery-item fade-in fade-in-delay-2"><img src="/images/gallery-6.jpg" alt="Another finished mosaic piece" loading="lazy"></div>
        <div class="gallery-item fade-in"><img src="/images/gallery-1.jpg" alt="Mosaic artwork" loading="lazy"></div>
        <div class="gallery-item fade-in fade-in-delay-1"><img src="/images/gallery-8.jpg" alt="Mosaic materials" loading="lazy"></div>
      </div>
    </div>
  </section>

  <div class="mosaic-divider"><span></span><span></span><span></span></div>

  <!-- CTA -->
  <section class="section mosaic-section mosaic-section--coral mosaic-clip-1" style="padding-top: 0; padding-bottom: 120px;">
    <div class="container">
      <CTABanner 
        title="Want to make your own?"
        description="Join an upcoming workshop and create something beautiful."
        buttonText="View Classes"
        buttonLink="/classes"
      />
    </div>
  </section>

  <Lightbox />
</Base>
