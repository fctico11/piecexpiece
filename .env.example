# Stripe keys — find these at dashboard.stripe.com/apikeys
# Use sk_test_... during development, sk_live_... in production
STRIPE_SECRET_KEY=paste_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=paste_your_stripe_publishable_key_here
# Webhook secret — from dashboard.stripe.com/webhooks
# Set the endpoint URL to: https://yourdomain.com/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=paste_your_webhook_secret_here

# Password to access /admin (the theme editor portal)
ADMIN_PASSWORD=your-secure-password-here

# GitHub personal access token — needs repo Contents write permission
# Create at: https://github.com/settings/tokens (classic) or fine-grained with "Contents: Read and write"
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your GitHub repo details
GITHUB_OWNER=fctico11
GITHUB_REPO=piecexpiece
GITHUB_BRANCH=main
